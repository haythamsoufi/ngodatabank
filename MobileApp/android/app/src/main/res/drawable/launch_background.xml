<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash screen matching Flutter splash screen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient background matching Flutter splash screen -->
    <item android:drawable="@drawable/launch_gradient" />

    <!-- App icon centered -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
