# Copy to `.env` in this directory for local development (`flutter_dotenv` loads it at startup).
# `.env` is gitignored. Do not commit real secrets.
#
# Compile-time defines (also used in CI) - see `lib/config/app_config.dart`:
#   --dart-define=BACKEND_URL=...     (wins over `.env` BACKEND_URL when non-empty)
#   --dart-define=MOBILE_APP_API_KEY=...  (used if `.env` does not set the key)
#   --dart-define=MAPBOX_ACCESS_TOKEN=pk...  (optional; home FDRS map — same as below)
#   --dart-define=SENTRY_DSN=...        (Sentry is define-only; not read from `.env`)
#   --dart-define=ORGANIZATION_CONFIG=ifrc   (which `assets/config/organization_config.*.json`)

# --- Environment preset (at most one should be `true`; omit all to default backoffice URL) ---
# PRODUCTION=true   -> https://databank.ifrc.org
# STAGING=true      -> https://databank-stage.ifrc.org
# DEVELOPMENT=true  -> localhost / 10.0.2.2 (Android emulator)
# PRODUCTION=false
# STAGING=false
# DEVELOPMENT=false

# --- URLs (optional; used when `BACKEND_URL` / `FRONTEND_URL` are not set via --dart-define) ---
# BACKEND_URL=http://10.0.2.2:5000
# FRONTEND_URL=http://10.0.2.2:3000

# --- Mobile API key (Backoffice API management / DB-managed key) ---
# MOBILE_APP_API_KEY=

# Legacy alias for the same key:
# API_KEY=

# --- Mapbox (public token; FDRS world map on home — see `lib/widgets/home_landing/fdrs_world_map.dart`) ---
# If unset, the map uses Carto tiles instead.
# MAPBOX_ACCESS_TOKEN=

# --- Debug ---
# VERBOSE_LOGS=true
