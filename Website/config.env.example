# =============================================================================
# Environment Configuration for NGO Databank Website
# =============================================================================
# Copy this file to .env.local and update the values as needed
#
# Note: All NEXT_PUBLIC_* variables are exposed to the browser
# =============================================================================

# Public display name — set to match Backoffice Settings → Organization branding
# (organization name). When unset, the site uses navigation.siteTitle from locales.
# NEXT_PUBLIC_ORGANIZATION_NAME=NGO Databank

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# Public API URL (required)
# Used by client-side code to connect to the backend API
#
# Development (local backend):
NEXT_PUBLIC_API_URL=http://localhost:5000
#
# Production (Fly.io backend):
# NEXT_PUBLIC_API_URL=https://backoffice-databank.fly.dev

# API Key (optional)
# Default: 'databank2026' (if not set)
NEXT_PUBLIC_API_KEY=databank2026

# Backoffice AI public proxy secret (RECOMMENDED)
# -----------------------------------------------------------------------------
# This value is used server-side by Next.js API routes to call Backoffice AI for
# anonymous/public users. Do NOT prefix with NEXT_PUBLIC_.
#
# Must match Backoffice `AI_PUBLIC_PROXY_SECRET`.
AI_PUBLIC_PROXY_SECRET=

# Internal API URL (optional)
# Used for server-side (SSR/build) requests, especially in Docker containers
# If not set, falls back to NEXT_PUBLIC_API_URL
# Example for Docker: http://backoffice:5000
# NEXT_INTERNAL_API_URL=http://backoffice:5000

# -----------------------------------------------------------------------------
# Data Store Configuration
# -----------------------------------------------------------------------------

# Enable local data store (default: true)
# When enabled, data is cached locally:
#   - Server-side: JSON files in /data directory
#   - Client-side: IndexedDB in browser
# Set to 'false' to always fetch from API
NEXT_PUBLIC_USE_LOCAL_STORE=true

# Force API usage (default: false)
# When set to 'true', bypasses local data store and always fetches from API
# Useful for debugging or ensuring fresh data
NEXT_PUBLIC_FORCE_API=false

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------

# Node Environment
# Options: 'development' | 'production' | 'test'
# Usually set automatically by Next.js, but can be overridden
NODE_ENV=development

# -----------------------------------------------------------------------------
# Demo / Deployment Scope
# -----------------------------------------------------------------------------

# Enable demo banner + scope dropdown (default: false)
NEXT_PUBLIC_DEMO_MODE=false

# Deployment scope when not in demo mode:
# - "global" (default)
# - ISO2 country code (National Society deployment), e.g. "SY"
NEXT_PUBLIC_DEPLOYMENT_SCOPE=global

# -----------------------------------------------------------------------------
# Activity Views (Domestic / International)
# -----------------------------------------------------------------------------
#
# Domestic: current indicator-based maps (world map + NS country map)
# International: cross-border support maps (future: support flows, etc.)
#
# If only one of these is enabled, the UI will not show tabs (it will show a title only).
NEXT_PUBLIC_ENABLE_DOMESTIC=true
NEXT_PUBLIC_ENABLE_INTERNATIONAL=false
#
# Optional: choose which tab is selected by default when both are enabled
# Options: domestic | international
# NEXT_PUBLIC_DEFAULT_ACTIVITY_VIEW=domestic

# For now (demo/dev) the Website uses a dummy JSON file and an API route:
# - `Website/data/international_dummy.json`
# - `Website/pages/api/international-support.js`
# Eventually this will be served/proxied from Backoffice.

# -----------------------------------------------------------------------------
# Mapbox (for country-scope map in demo/national deployments)
# -----------------------------------------------------------------------------

# Mapbox public token for map rendering
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.***

# Disable Fast Refresh (optional)
# Set to 'true' to disable Next.js Fast Refresh for debugging
# DISABLE_FAST_REFRESH=true
