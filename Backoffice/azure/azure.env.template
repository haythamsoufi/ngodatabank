# Azure App Service Environment Variables Template
# Copy these settings to Azure Portal > App Service > Configuration > Application Settings
# DO NOT commit actual secrets to git!

# ===========================================
# Flask Configuration
# ===========================================
FLASK_CONFIG=production
FLASK_APP=run:app
SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(32))">

# ===========================================
# Database Configuration
# ===========================================
# Format: postgresql+psycopg2://USERNAME:PASSWORD@SERVERNAME.postgres.database.azure.com:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql+psycopg2://ifrcadmin:PASSWORD@SERVER.postgres.database.azure.com:5432/ifrc_databank?sslmode=require

# Database connection pool settings
# Total max DB connections = GUNICORN_WORKERS × (POOL_SIZE + MAX_OVERFLOW)
# Azure PostgreSQL max_connections = 250 (Server parameters → max_connections).
# PostgreSQL reserves ~5 slots for superusers → ~245 usable.
# With 5 gunicorn workers: 5 × (10 + 20) = 150 connections — uses 60% of the limit,
# leaving ~100 for admin tools, psql sessions, migrations, staging slots, and monitoring.
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_RECYCLE=300
SQLALCHEMY_POOL_TIMEOUT=60

# ===========================================
# Application Settings
# ===========================================
API_KEY=<generate-random-32-char-string>
BASE_URL=https://your-app-name.azurewebsites.net
UPLOAD_FOLDER=/home/site/wwwroot/uploads
# Azure Blob Storage for file uploads (set by azure-deploy.sh/.ps1 automatically)
AZURE_STORAGE_CONNECTION_STRING=<from-az-storage-account-show-connection-string>
AZURE_STORAGE_CONTAINER=uploads

# ===========================================
# Azure Build Settings
# ===========================================
SCM_DO_BUILD_DURING_DEPLOYMENT=true
ENABLE_ORYX_BUILD=true
POST_BUILD_COMMAND=npm install && npm run build:css
WEBSITES_PORT=5000
WEBSITES_CONTAINER_START_TIME_LIMIT=600

# ===========================================
# Gunicorn/WSGI Settings
# ===========================================
WEB_CONCURRENCY=4
GUNICORN_CMD_ARGS=--timeout 300 --workers 4 --threads 2

# ===========================================
# Email Configuration (SMTP)
# ===========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=NGO Databank <noreply.databank@ifrc.org>
MAIL_NOREPLY_SENDER=NGO Databank <noreply.databank@ifrc.org>
ADMIN_EMAILS=admin@ifrc.org
TEAM_EMAIL=team@ifrc.org

# ===========================================
# Email Transport (API providers)
# ===========================================
# Use 'api' to send via provider API, or 'smtp' to use SMTP relay
EMAIL_TRANSPORT=api
# Providers: sendgrid, mailgun
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-api-key
# Mailgun specific settings
EMAIL_DOMAIN=your.mailgun.domain
MAILGUN_API_BASE=https://api.mailgun.net/v3
# SendGrid specific settings
SENDGRID_API_URL=https://api.sendgrid.com/v3/mail/send

# ===========================================
# AI Chatbot Configuration
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
GEMINI_API_KEY=your-gemini-api-key
CHATBOT_ENABLED=true
CHATBOT_MAX_HISTORY=10
CHATBOT_SERVICE_PRIORITY=openai,gemini,fallback
# Max document-search calls per AI agent run (helps avoid repeated near-duplicate searches)
AI_AGENT_SEARCH_DOCS_MAX_CALLS=5
# Max completion tokens per agent turn (allows full 192-row all-countries tables; default 32768)
# AI_AGENT_MAX_COMPLETION_TOKENS=32768

# ===========================================
# Security Settings
# ===========================================
SECURITY_HEADERS_ENABLED=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_ENABLED=true
WTF_CSRF_SSL_STRICT=true

# CORS Configuration
# Comma-separated list of allowed origins (REQUIRED in production)
# Example: https://app.example.com,https://www.example.com
# If not set, CORS is disabled by default for security
CORS_ALLOWED_ORIGINS=https://your-app-name.azurewebsites.net

# ===========================================
# Monitoring (Application Insights)
# ===========================================
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key-here
APPINSIGHTS_INSTRUMENTATIONKEY=your-key-here

# ===========================================
# Logging
# ===========================================
LOG_TO_STDOUT=true
LOG_LEVEL=INFO
VERBOSE_FORM_DEBUG=false

# ===========================================
# Session Configuration
# ===========================================
PERMANENT_SESSION_LIFETIME_HOURS=1
SESSION_INACTIVITY_TIMEOUT_MINUTES=30

# ===========================================
# Development/Debug
# ===========================================
DEBUG=false
