msgid ""
"<strong>Check similarity</strong> — click any dot to see its top "
"semantically similar indicators with similarity scores"
msgstr ""
"<strong>Ellenőrizd a hasonlóságot</strong> — kattints bármelyik pontra, hogy"
" lásd a legjelentősebb szemantikailag hasonló mutatókat hasonlósági "
"pontszámokkal"

msgid ""
"<strong>Discover duplicates</strong> — indicators clustered tightly may "
"overlap in meaning"
msgstr ""
"<strong>Ismerd meg a duplikátumokat</strong> — a szorosan csoportosított "
"indikátorok jelentésük átfedhet"

msgid ""
"<strong>Explore clusters</strong> — colour by sector, programme, or type to "
"see how indicators group"
msgstr ""
"<strong>Fedezze fel a klasztereket</strong> — szín szektor, program vagy "
"típus szerint, hogy megnézze, hogyan csoportosulnak a mutatók"

msgid ""
"<strong>Find gaps</strong> — sparse areas may indicate missing coverage"
msgstr ""
"<strong>Találj rések</strong> — a ritka területek hiányzó lefedettséget "
"jelezhetnek"

msgid ""
"<strong>Tip:</strong> Switch to <em>t-SNE</em> for better local grouping — "
"it specifically optimises for keeping neighbours together, reducing the "
"\"distant but similar\" effect."
msgstr ""
"<strong>Tipp:</strong> Válts <em>át t-SNE-re</em> a jobb helyi csoportosítás"
" érdekében — kifejezetten optimalizálja a szomszédok összetartását, "
"csökkentve a \"távoli, de hasonló\" hatást."

