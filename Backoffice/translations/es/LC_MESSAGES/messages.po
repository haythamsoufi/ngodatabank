#: app/templates/admin/indicator_bank/neural_map.html:224
msgid ""
"<strong>Check similarity</strong> — click any dot to see its top "
"semantically similar indicators with similarity scores"
msgstr ""
"<strong>Comprueba la similitud</strong> — haz clic en cualquier punto para "
"ver sus principales indicadores semánticamente similares con puntuaciones de"
" similitud"

#: app/templates/admin/indicator_bank/neural_map.html:221
msgid ""
"<strong>Discover duplicates</strong> — indicators clustered tightly may "
"overlap in meaning"
msgstr ""
"<strong>Descubre duplicados</strong> — los indicadores agrupados de forma "
"muy estrecha pueden solaparse en significado"

#: app/templates/admin/indicator_bank/neural_map.html:223
msgid ""
"<strong>Explore clusters</strong> — colour by sector, programme, or type to "
"see how indicators group"
msgstr ""
"<strong>Explora los clústeres</strong> — colorea por sector, programa o tipo"
" para ver cómo se agrupan los indicadores"

#: app/templates/admin/indicator_bank/neural_map.html:222
msgid ""
"<strong>Find gaps</strong> — sparse areas may indicate missing coverage"
msgstr ""
"<strong>Encontrar huecos</strong> — las áreas escasas pueden indicar "
"cobertura ausente"

#: app/templates/admin/indicator_bank/neural_map.html:247
msgid ""
"<strong>Tip:</strong> Switch to <em>t-SNE</em> for better local grouping — "
"it specifically optimises for keeping neighbours together, reducing the "
"\"distant but similar\" effect."
msgstr ""
"<strong>Propina:</strong> Cambia a <em>t-SNE</em> para una mejor agrupación "
"local — optimiza específicamente para mantener unidos a los vecinos, "
"reduciendo el efecto de \"distante pero similar\"."

