# Minimal environment for local development.
# Copy to `Backoffice/.env` and fill in the values you actually need.
#
# Full reference catalog lives in: `Backoffice/env.example`
#
# ----------------------------------------------------------------------------
# App mode (development | staging | production | testing)
FLASK_CONFIG=development

# Required for sessions/CSRF (set a stable value so logins survive restarts)
SECRET_KEY=dev_change_me

# Database (Postgres required; no SQLite fallback)
DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/hum_databank

# Optional (recommended): use a separate DB for tests
TEST_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/hum_databank_test

# Frontend URL (for redirects + some CORS defaults)
FRONTEND_URL=http://localhost:3000

# Optional (prod): comma-separated origins to allow CORS
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=

# Optional: Email sender (some flows will warn if unset)
MAIL_DEFAULT_SENDER=

# ----------------------------------------------------------------------------
# Test user passwords (development only)
# These enable quick-login buttons on the login page.
# Run `flask seed-test-data` after `flask db upgrade` to create the test users.
TEST_ADMIN_PASSWORD=test123
TEST_FOCAL_PASSWORD=test123
TEST_SYS_MANAGER_PASSWORD=test123

# ----------------------------------------------------------------------------
# AI (optional) — keys & env-only secrets only. Tune models and behaviour in
# Admin → System Configuration → AI (database). See env.example AI section.
OPENAI_API_KEY=

# Website anonymous chatbot hardening (optional): same value in Website proxy header.
AI_PUBLIC_PROXY_SECRET=

# ----------------------------------------------------------------------------
# External GO/document API import (optional; AI Documents — uses IFRC_* env names for compatibility)
IFRC_API_USER=
IFRC_API_PASSWORD=
