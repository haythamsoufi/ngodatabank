# Minimal environment for local development.
# Copy to `Backoffice/.env` and fill in the values you actually need.
#
# Full reference catalog lives in: `Backoffice/env.example`
#
# ----------------------------------------------------------------------------
# App mode (development | staging | production | testing)
FLASK_CONFIG=development

# Required for sessions/CSRF (set a stable value so logins survive restarts)
SECRET_KEY=dev_change_me

# Database (Postgres required; no SQLite fallback)
DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/ngo_databank

# Optional (recommended): use a separate DB for tests
TEST_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/ngo_databank_test

# Frontend URL (for redirects + some CORS defaults)
FRONTEND_URL=http://localhost:3000

# Optional (prod): comma-separated origins to allow CORS
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=

# Optional: Email sender (some flows will warn if unset)
MAIL_DEFAULT_SENDER=

# ----------------------------------------------------------------------------
# AI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# If you want to enable a public Website chatbot safely, set this shared secret
# and configure the Website server to send it as `X-NGO-Databank-AI-Proxy`.
AI_PUBLIC_PROXY_SECRET=

# ----------------------------------------------------------------------------
# External GO/document API import (optional; AI Documents — uses IFRC_* env names for compatibility)
IFRC_API_USER=
IFRC_API_PASSWORD=
