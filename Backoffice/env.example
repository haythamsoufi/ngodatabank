# ============================================================================
# FLASK APPLICATION CONFIGURATION
# ============================================================================

# Environment selector: development | staging | production | testing
# Controls which config class is loaded, email routing, HTTPS, debug mode, etc.
FLASK_CONFIG=development
# Browser console verbosity (console.log / debug / info / warn / …) on Backoffice pages.
# If unset, follows DEBUG (on in development/default, off in staging/production/testing).
# CLIENT_CONSOLE_LOGGING=true|false
CLIENT_CONSOLE_LOGGING=
# Strict env validation (fail fast on missing/dangerous config)
# - production/staging default: strict
# - development/testing default: non-strict
# Override defaults with STRICT_ENV_VALIDATION=true/false
STRICT_ENV_VALIDATION=
# SECURITY: Generate a secure SECRET_KEY and set it here for persistent sessions.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This is CRITICAL for session security, CSRF protection, and token generation.
# If left empty in development, a secure random key is auto-generated per restart
# (sessions reset on every app restart). Required in production — app will not start.
# WARNING: 'dev_change_me' and similar weak values are rejected in production/staging.
SECRET_KEY=
BASE_URL=http://localhost:5000

# File Upload Configuration
# ----------------------------------------------------------------------------
# Directory for storing uploaded files (defaults to instance/uploads if not set)
UPLOAD_FOLDER=

# Maximum file upload size — enter value in **megabytes** (e.g. 25 for 25 MB, 50 for 50 MB).
# Despite the variable name containing "BYTES", the Backoffice config reads this as MB and
# converts internally (MAX_UPLOAD_SIZE_BYTES = value × 1024 × 1024). Defaults to 25 MB.
MAX_UPLOAD_SIZE_BYTES=25

# Azure Blob Storage for file uploads (optional)
# ----------------------------------------------------------------------------
# When set, uploaded files (documents, resources, submissions, logos, AI docs)
# are stored in Azure Blob Storage instead of the local filesystem.
# Auto-detected: if AZURE_STORAGE_CONNECTION_STRING is set, azure_blob is used;
# otherwise falls back to local UPLOAD_FOLDER. Override with UPLOAD_STORAGE_PROVIDER.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=uploads
# Explicit provider override: filesystem | azure_blob (auto-detected if not set)
# UPLOAD_STORAGE_PROVIDER=


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/hum_databank
DEV_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/hum_databank
# Test database URL (required for running tests)
# For Docker Compose: Automatically set to db-test service (port 5433)
# For local development: Create a separate test database: CREATE DATABASE test_db;
# Docker Compose: postgresql+psycopg2://app:app@db-test:5432/hum_databank_test
# Local/Outside Docker: postgresql+psycopg2://app:app@localhost:5432/test_db
# Host machine accessing Docker test DB: postgresql+psycopg2://app:app@localhost:5433/hum_databank_test
TEST_DATABASE_URL=postgresql+psycopg2://app:app@localhost:5432/hum_databank_test
SQLALCHEMY_POOL_RECYCLE=300
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=30
SQLALCHEMY_POOL_TIMEOUT=60


# ============================================================================
# EMAIL CONFIGURATION (hosted email API — set URLs for your provider)
# ============================================================================

# Global Email Settings
# ----------------------------------------------------------------------------
# REQUIRED: Used as the "From" address for all emails
MAIL_DEFAULT_SENDER=

# Optional: Used for system notifications (falls back to MAIL_DEFAULT_SENDER if not set)
MAIL_NOREPLY_SENDER=

# Optional: Comma-separated list of admin emails for notifications
#   Example: admin1@example.org,admin2@example.org
ADMIN_EMAILS=

# Optional: Used for BCC in some emails (falls back to MAIL_DEFAULT_SENDER if not set)
TEAM_EMAIL=

# Legacy: Recipient email protection is disabled. This variable is unused and kept for backwards compatibility only.
ALLOWED_EMAIL_RECIPIENTS_DEV=

# Email API Configuration
# ----------------------------------------------------------------------------
# General API key (fallback if environment-specific keys are not set)
EMAIL_API_KEY=

# Environment-specific API keys (take precedence based on FLASK_CONFIG)
EMAIL_API_KEY_PROD=
EMAIL_API_KEY_STG=

# API endpoints (automatically selected based on FLASK_CONFIG).
# Code defaults are empty — set these to your organization’s email API gateway URLs.
EMAIL_API_URL_PROD=
EMAIL_API_URL_STG=


# ============================================================================
# AI CHATBOT CONFIGURATION
# ============================================================================

# Public Website chatbot hardening (recommended)
# ----------------------------------------------------------------------------
# If set (RECOMMENDED in production), anonymous calls to /api/ai/v2/chat and
# /api/ai/v2/chat/stream must include header:
#   X-hum-databank-AI-Proxy: <AI_PUBLIC_PROXY_SECRET>
#
# The Website Next.js proxy (`Website/pages/api/chatbot.js`) should be configured
# to send this header for public (unauthenticated) users.
AI_PUBLIC_PROXY_SECRET=

# Primary Chatbot (OpenAI - same as RAG system)
# ----------------------------------------------------------------------------
CHATBOT_ENABLED=false
CHATBOT_MAX_HISTORY=10
# Optional: display name shown in the chat UI
CHATBOT_NAME=
# Max characters per chat message (validation in AI v2 chat)
# (see also AI section below)
# AI_MAX_MESSAGE_CHARS=4000

# Fallback Option A (Gemini)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=

# Fallback Option B (Azure OpenAI)
# ----------------------------------------------------------------------------
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Fallback Option C (GitHub Copilot)
# ----------------------------------------------------------------------------
COPILOT_API_KEY=
COPILOT_API_ENDPOINT=https://api.githubcopilot.com
COPILOT_MODEL=gpt-4

# ============================================================================
# AI CHAT PERSISTENCE: RETENTION & ARCHIVING
# ============================================================================

# Enable/disable retention & archiving jobs (API still works either way)
AI_CHAT_RETENTION_ENABLED=true

# Archive provider: filesystem | azure_blob
AI_CHAT_ARCHIVE_PROVIDER=filesystem

# Archive conversations older than this many days (removes messages from DB after successful archive)
AI_CHAT_ARCHIVE_AFTER_DAYS=90

# Purge conversations older than this many days (deletes conversation + archive)
AI_CHAT_PURGE_AFTER_DAYS=365

# Batch size for maintenance jobs (archive/purge)
AI_CHAT_MAINTENANCE_BATCH_SIZE=200

# Filesystem archiving: subfolder under UPLOAD_FOLDER (or instance/uploads)
AI_CHAT_ARCHIVE_DIR=ai_chat_archives

# Optional: Encrypt archives at rest (Fernet key: urlsafe base64-encoded 32 bytes)
# If unset, archives are stored as gzipped JSON on disk/blob.
AI_CHAT_ARCHIVE_ENCRYPTION_KEY=

# Azure Blob archiving (used only when AI_CHAT_ARCHIVE_PROVIDER=azure_blob)
AI_CHAT_ARCHIVE_AZURE_CONNECTION_STRING=
AI_CHAT_ARCHIVE_AZURE_CONTAINER=ai-chat-archives

# Export limits (protects server memory + response size)
AI_CHAT_EXPORT_MAX_MESSAGES=5000
AI_CHAT_EXPORT_MAX_BYTES=10485760


# ============================================================================
# AI RAG SYSTEM & AGENTIC REASONING
# ============================================================================
# Advanced AI capabilities: document search, multi-step reasoning, tool use

# Enable/disable the AI Agent (RAG + agentic reasoning)
# When enabled, the agent can use tools, search documents, and reason step-by-step
# Requires OPENAI_API_KEY to be set
AI_AGENT_ENABLED=true

# OpenAI Configuration (required for chatbot, agent, and embeddings)
# ----------------------------------------------------------------------------
# Primary LLM provider - used by chatbot, RAG system, and agent
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model for chatbot, agent reasoning, and RAG (default: gpt-5-mini)
# Note: model availability depends on your OpenAI account.
OPENAI_MODEL=gpt-5-mini

# Embedding Configuration
# ----------------------------------------------------------------------------
# Provider for generating document embeddings
# Options: openai (recommended), local (free but lower quality)
AI_EMBEDDING_PROVIDER=openai

# OpenAI embedding model (default: text-embedding-3-small)
# Options: text-embedding-3-small (1536 dims), text-embedding-3-large (3072 dims)
AI_EMBEDDING_MODEL=text-embedding-3-small

# Embedding dimensions (must match the model)
AI_EMBEDDING_DIMENSIONS=1536

# Max document upload size for AI processing (MB)
# AI_MAX_DOCUMENT_SIZE_MB=50

# Document Chunking Configuration
# ----------------------------------------------------------------------------
# Maximum tokens per chunk (smaller = more precise, larger = more context)
AI_CHUNK_SIZE=512

# Overlap between chunks in tokens (helps maintain context across boundaries)
AI_CHUNK_OVERLAP=50

# Chunking strategy: semantic (recommended), fixed, paragraph, recursive
# NOTE: Currently not read by the Backoffice code (kept for forward compatibility).
# AI_CHUNKING_STRATEGY=semantic

# PDF Table Extraction (structured table chunks)
# ----------------------------------------------------------------------------
# When enabled, the processor will attempt to extract tables from PDFs into structured
# chunks (in addition to normal text chunks). This improves reliability for numeric/table queries.
AI_TABLE_EXTRACTION_ENABLED=true
AI_EXCLUDE_TABLE_TEXT_FROM_PDF_TEXT=true
AI_TABLE_EXTRACT_COLORS_ENABLED=false

# Vector Search Configuration
# ----------------------------------------------------------------------------
# Number of results to return from semantic search
AI_TOP_K_RESULTS=5
# Max chunks for list-style document search (return_all_countries=True). Default 500 for ~300-doc corpora.
# AI_DOCUMENT_SEARCH_MAX_TOP_K_LIST=500
# Minimum hybrid score floor (0-1) for return_all_countries queries. 0 disables. Default 0.3.
# AI_DOCUMENT_SEARCH_MIN_SCORE=0.3
# Adaptive ratio: threshold = max(MIN_SCORE, top_score * RATIO). Default 0.45.
# AI_DOCUMENT_SEARCH_MIN_SCORE_RATIO=0.45
# Batch size for document search pagination (LLM fetches offset=0, offset=limit, ... until done). Default 100.
# AI_SEARCH_DOCUMENTS_BATCH_SIZE=100
# Max characters for document-search tool observation (full chunk content; no preview). Default 10M. No truncation of content.
# Cap document-search tool observation size (50k-500k). Default 120000.
# AI_TOOL_OBSERVATION_MAX_CHARS_DOCUMENT_SEARCH=120000
# When over cap, truncate each chunk content to this many chars (default 500).
# AI_TOOL_OBSERVATION_DOCUMENT_SEARCH_MAX_CONTENT_PER_CHUNK=500

# Reranking: after hybrid search, rerank with cross-encoder/API for better precision (e.g. 200+ docs)
# Set to true and configure AI_RERANK_PROVIDER and (for Cohere) COHERE_API_KEY
AI_RERANK_ENABLED=false
# Rerank provider: cohere (needs COHERE_API_KEY), or local (sentence-transformers cross-encoder)
AI_RERANK_PROVIDER=cohere
# Max results to return after reranking
AI_RERANK_TOP_K=20
# Local cross-encoder model when AI_RERANK_PROVIDER=local (e.g. cross-encoder/ms-marco-MiniLM-L-6-v2)
# AI_RERANK_LOCAL_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Document diversity: max chunks per document in hybrid results (0 = no cap). Helps when searching 200+ docs.
AI_DOCUMENT_DIVERSITY_MAX_CHUNKS_PER_DOC=10

# Cohere API key (optional; only needed when AI_RERANK_ENABLED=true and AI_RERANK_PROVIDER=cohere)
# COHERE_API_KEY=
# Optional: Cohere rerank model (default: rerank-v3.5)
# AI_RERANK_COHERE_MODEL=rerank-v3.5

# Minimum similarity score (0-1) for search results
# NOTE: Currently not read by the Backoffice code (kept for forward compatibility).
# AI_SIMILARITY_THRESHOLD=0.7

# Agent Runtime
# ----------------------------------------------------------------------------
# Most operational AI limits are intentionally fixed in config.py to reduce env complexity.
# Keep only provider selection/keys here unless you need custom behavior.
# Max number of document-search tool calls per agent run (prevents redundant loops).
AI_AGENT_SEARCH_DOCS_MAX_CALLS=5

# Query rewrite: rewrite the user message before passing to agent/LLM (improves tool use)
# AI_QUERY_REWRITE_ENABLED=true
# Optional: override model used for query rewrite (if unset, uses OPENAI_MODEL)
# AI_QUERY_REWRITE_MODEL=

# Response revision: run every final response through an LLM (default: false to reduce cost)
# AI_RESPONSE_REVISION_ENABLED=false
# AI_RESPONSE_REVISION_MAX_TOKENS=1500

# Pagination: max search_documents batches per run (default 2). Higher = more rounds, higher cost.
# AI_AGENT_SEARCH_DOCS_PAGINATION_MAX_BATCHES=2

# Fast-path document list: max chunks and chars per chunk sent to synthesis LLM
# AI_FASTPATH_DOCUMENT_LIST_MAX_CHUNKS=80
# AI_FASTPATH_DOCUMENT_LIST_MAX_CONTENT_CHARS=400

# Tool caching
# AI_TOOL_CACHE_ENABLED=true
# AI_TOOL_CACHE_TTL_SECONDS=300
# AI_DOCUMENT_SEARCH_SANITIZE_QUERY=true

# Indicator resolution / bulk limits (agent)
# AI_INDICATOR_MAX_COUNTRIES=250
# Method: vector | vector_then_llm | keyword
# AI_INDICATOR_RESOLUTION_METHOD=vector
# AI_INDICATOR_LLM_DISAMBIGUATE=true
# AI_INDICATOR_TOP_K=10

# Outbound AI timeout and API rate limits are fixed in config.py.

# Max characters per chat message (validation in AI v2 chat)
# Optional Redis (cross-worker rate limiting / WebSocket throttling). If unset, in-memory per worker.
# REDIS_URL=
# Flask-Limiter storage backend. Defaults to in-memory (per-worker, not shared across Gunicorn workers).
# Set to a Redis URI for production multi-worker deployments.
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# Maximum completion tokens for v2 chat streaming responses (default: 1200)
AI_CHAT_MAX_COMPLETION_TOKENS=1200

# Maximum completion tokens per agent LLM turn (ReAct and native). Default 32768 allows full 192-row all-countries tables.
# AI_AGENT_MAX_COMPLETION_TOKENS=32768

# Use native function calling (recommended) vs custom ReAct
AI_USE_NATIVE_FUNCTION_CALLING=true

# Function calling provider: openai (recommended), gemini
AI_FUNCTION_CALLING_PROVIDER=openai

# AI Form-Data Validation
# ----------------------------------------------------------------------------
# Max completion tokens for the OpenAI call during form-data validation (default: 3000, clamped 800-8000)
AI_FORMDATA_VALIDATION_MAX_COMPLETION_TOKENS=3000

# Max chunks per document used in validation prompt (keeps sources varied; default: 2)
AI_VALIDATION_MAX_CHUNKS_PER_DOC=2

# Force inclusion of system-upload document chunks in validation context (default: false)
AI_VALIDATION_FORCE_SYSTEM_SOURCE=false

# Optional: Multi-modal and OCR
# ----------------------------------------------------------------------------
# Enable image extraction from documents (requires additional dependencies)
AI_MULTIMODAL_ENABLED=true

# Enable OCR for scanned PDFs (requires pytesseract and Tesseract installed)
AI_OCR_ENABLED=true

# Indicator resolution (map user phrase like "volunteers" to Indicator Bank)
# ----------------------------------------------------------------------------
# Method: vector (semantic search on indicator embeddings), vector_then_llm (+ LLM pick-one), or keyword (legacy ILIKE)
# AI_INDICATOR_RESOLUTION_METHOD=vector
# When vector_then_llm: use LLM to disambiguate among top-k (needs OPENAI_API_KEY)
# AI_INDICATOR_LLM_DISAMBIGUATE=true
# Number of candidates from vector search (then optional LLM)
# AI_INDICATOR_TOP_K=10
# After enabling vector/vector_then_llm, run: flask sync-indicator-embeddings


# ============================================================================
# TRANSLATION API CONFIGURATION
# ============================================================================

# Hosted translation API (default translation service; internal id "ifrc" in app code)
# ----------------------------------------------------------------------------
# API key for hosted translation service (IFRC_TRANSLATE_* names kept for compatibility)
# If not set, this translation backend is disabled
IFRC_TRANSLATE_API_KEY=

# Hosted translation API endpoint URL
# Defaults to staging if not set
IFRC_TRANSLATE_URL=https://your-translation-api.example.org

# Google Translate API (Alternative Service)
# ----------------------------------------------------------------------------
# API key for Google Translate service (optional)
# If set, Google Translate will be available as an alternative translation service
GOOGLE_TRANSLATE_API_KEY=

# LibreTranslate API (Alternative Service)
# ----------------------------------------------------------------------------
# API key for LibreTranslate service (optional)
# If set, LibreTranslate will be available as an alternative translation service
LIBRE_TRANSLATE_API_KEY=

# Legacy/compat: older deployments may use TRANSLATE_API_KEY for Google Translate.
TRANSLATE_API_KEY=

# Debugging: verbose translation logs (1/true/yes/on)
AUTO_TRANSLATE_DEBUG=


# ============================================================================
# FDRS DATA IMPORT (scripts/import_fdrs_form_data.py)
# ============================================================================
# API key for IFRC FDRS data API (https://data-api.ifrc.org).
# Required when running the FDRS import script without --fdrs-data-api-key flag.
# Obtain from the IFRC data-api.ifrc.org portal.
FDRS_DATA_API_KEY=

# Bearer token for the Databank API (this application).
# Used by the FDRS import script to call /api/v1/assigned-forms, /api/v1/form-items,
# and /api/v1/indicator-bank.  Falls back to DATABANK_API_KEY then API_KEY.
# Generate an API key in the Admin → API Management panel.
FDRS_DATABANK_API_KEY=

# ============================================================================
# REMOTE INDICATOR BANK SYNC (optional; IFRC_* names kept for compatibility)
# ============================================================================
# Temporary: until indicator bank is fully migrated into this system.
#
# API key for external Indicator Bank endpoint:
#   GET https://ifrc-indicatorbank.azurewebsites.net/api/indicator
#   Obtain the key from your IFRC Indicator Bank administrator.
IFRC_INDICATORBANK_API_KEY=

# Optional override for the remote endpoint URL:
IFRC_INDICATORBANK_API_URL=https://your-indicator-bank.example.org/api/indicator

# GO / external document API (optional)
# ----------------------------------------------------------------------------
# API key for GO-style public API (document imports when your deployment uses it)
# Required for accessing PublicSiteAppeals endpoint
IFRC_GO_API_KEY=

# External document import (AI Documents)
# ----------------------------------------------------------------------------
# SECURITY: Required for importing documents from allowed external URLs via the Backoffice
# AI document import endpoints. Credentials are supplied via environment variables.
IFRC_API_USER=
# Backwards-compatible alias (some deployments used IFRC_API_USERNAME instead of IFRC_API_USER)
IFRC_API_USERNAME=
IFRC_API_PASSWORD=
#
# SSRF protection allowlist for external document fetching (comma-separated hosts).
# Defaults are restrictive in code; set this if you need additional domains.
# Example:
# IFRC_DOCUMENT_ALLOWED_HOSTS=api.ifrc.org,go.ifrc.org,go-api.ifrc.org,ifrc.org,prddsgolocstor01.blob.core.windows.net
IFRC_DOCUMENT_ALLOWED_HOSTS=

# LibreTranslate endpoint URL (optional)
# Defaults to http://localhost:5000 if not set
# Only used if LIBRE_TRANSLATE_API_KEY is set
LIBRE_TRANSLATE_URL=


# ============================================================================
# API & FRONTEND CONFIGURATION
# ============================================================================

# Mobile app shared key (Flutter MOBILE_APP_API_KEY): X-Mobile-Auth + Bearer on /api/v1.
# Validated against api_keys (preferred) or this env when no matching DB row exists.
# MOBILE_APP_API_KEY=
# Per-minute in-process rate limit for env-only matches (default 300).
# MOBILE_APP_API_KEY_RATE_LIMIT_PER_MINUTE=300

# Optional minimum mobile app semver for /api/mobile/v1 (X-App-Version). Prefer Admin →
# System Configuration → Minimum mobile app version (system_settings). This env is used
# only when the DB value is unset.
# MOBILE_MIN_APP_VERSION=2.0.0

# Website URL for CORS and redirects
FRONTEND_URL=http://localhost:3000

# Optional: base URL used when generating the OpenAPI spec (defaults to http://localhost:5000)
API_BASE_URL=

# CORS Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS.
# Example: https://app.example.com,https://www.example.com
# If not set in production, CORS is disabled by default for security.
# In development (FLASK_CONFIG=development), if this is UNSET, CORS defaults to:
#   http://localhost:5000, http://127.0.0.1:5000, http://localhost:3000, http://127.0.0.1:3000
# If you set this to a single origin (e.g. http://localhost:5000), the Website on port 3000
# will get "Failed to fetch" — add the Website origin, e.g.:
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000,http://127.0.0.1:5000
# Or leave unset for local dev so both Backoffice and Website work.
#
# If the public Website is on a different host than the Backoffice (e.g. Website on Fly.io and
# API on databank.ifrc.org), browsers need the Website origin listed here so /api/* CORS works
# for any client-side calls that hit the Backoffice directly. Example:
#   CORS_ALLOWED_ORIGINS=https://website-databank.fly.dev,https://databank.ifrc.org
CORS_ALLOWED_ORIGINS=

# Reverse proxy header trust (X-Forwarded-Proto/Host). Recommended true behind a proxy.
# Defaults: production=true, otherwise=false
TRUST_PROXY_HEADERS=


# ============================================================================
# AZURE AD B2C FEDERATION LOGIN
# ============================================================================

# Azure AD B2C tenant domain (e.g. your-tenant.onmicrosoft.com)
AZURE_B2C_TENANT=

# Policy name (custom policy) like: B2C_1A_PROD_MASTER_SIGNUP_SIGNIN (or TEST equivalent)
AZURE_B2C_POLICY=

# App registration of this application in the B2C tenant
AZURE_B2C_CLIENT_ID=
AZURE_B2C_CLIENT_SECRET=

# Public callback URL for your Flask app (must match app registration redirect URI)
AZURE_B2C_REDIRECT_URI=

# Where B2C redirects after logout (post_logout_redirect_uri).
# This URI MUST be registered in the B2C app registration (Authentication → Redirect URIs).
# Example: https://your-backoffice.example.org/login
# If unset, defaults to <base_url>/login (which still needs to be registered in B2C).
AZURE_B2C_POST_LOGOUT_REDIRECT_URI=

# Scopes requested from B2C; defaults used by code: "openid email profile"
AZURE_B2C_SCOPE=openid email profile


# ============================================================================
# PUSH NOTIFICATIONS (FCM V1 API)
# ============================================================================

# Download service account JSON from Firebase Console > Project Settings > Service Accounts
# Path to the service account JSON file (relative to Backoffice/ or absolute path)
FCM_SERVICE_ACCOUNT_PATH=your-firebase-adminsdk.json

# Firebase Project ID (can also be extracted from service account JSON)
FCM_PROJECT_ID=your-firebase-project


# ============================================================================
# MONITORING & FEATURES
# ============================================================================

# Memory Monitoring
# Enable runtime memory monitoring (logs memory usage to terminal)
# Set to 'true' to enable memory tracking for requests and operations
MEMORY_MONITORING_ENABLED=false

# System Monitoring
# Enable system monitoring (CPU, disk, database pool, threads, network)
# Set to 'true' to enable comprehensive system health tracking
SYSTEM_MONITORING_ENABLED=false

# Health Check Configuration
# ----------------------------------------------------------------------------
# Enable DB check as part of the public health endpoint (off by default).
HEALTH_CHECK_DB=false

# Logging Performance Optimization
# Verbose form/app debug: sets DEBUG logging, debug_utils helpers, and some guarded admin logs.
# Set to 'true' only when troubleshooting; default false (not recommended for production).
VERBOSE_FORM_DEBUG=false
# tracemalloc has 5-20% CPU overhead - disable by default in staging/production
# Set to 'true' only when actively debugging memory issues
TRACEMALLOC_ENABLED=false

# Log file rotation settings (prevents unbounded log growth and improves performance)
# Memory log: max size in bytes (default: 10MB)
MEMORY_LOG_MAX_BYTES=10485760
# Memory log: number of backup files to keep (default: 5)
MEMORY_LOG_BACKUP_COUNT=5

# System log: max size in bytes (default: 10MB)
SYSTEM_LOG_MAX_BYTES=10485760
# System log: number of backup files to keep (default: 5)
SYSTEM_LOG_BACKUP_COUNT=5

# Application log: max size in bytes (default: 50MB)
APPLICATION_LOG_MAX_BYTES=52428800
# Application log: number of backup files to keep (default: 5)
APPLICATION_LOG_BACKUP_COUNT=5

# WebSocket Configuration for Real-Time Notifications
# Enable WebSocket for real-time notification delivery and AI chat streaming
# Set to 'true' to enable WebSocket (default: true)
# Set to 'false' to disable WebSocket
WEBSOCKET_ENABLED=true


# Development Server Configuration
# ----------------------------------------------------------------------------
# Use Gunicorn for multi-threaded development (recommended for WebSocket support)
# Set to 'true' to use Gunicorn instead of Flask dev server
# Gunicorn provides proper multi-threading and WebSocket support
# Note: Gunicorn is Unix-only (Linux/Mac), not available on Windows
USE_GUNICORN_DEV=false

# Use gevent for Windows development (recommended for WebSocket support on Windows)
# Set to 'true' to use gevent instead of Flask dev server
# gevent provides proper WSGI and WebSocket support (cross-platform, actively maintained)
# If WEBSOCKET_ENABLED=true on Windows, gevent will be used automatically
# Note: Waitress does NOT support WebSocket upgrades, so gevent is used instead
USE_GEVENT_DEV=false
# Optional legacy alias (some setups use USE_GEVENT instead of USE_GEVENT_DEV)
USE_GEVENT=

# Flask Development Server Threading
# Enable threading in Flask dev server (limited WebSocket support)
# Only used if USE_GUNICORN_DEV=false and USE_GEVENT_DEV=false
# Set to 'true' to enable threading in Flask dev server
# Note: Flask dev server has limited WebSocket support, especially on Windows
FLASK_THREADED=true

# Gunicorn Configuration (Production)
# ----------------------------------------------------------------------------
# Number of worker processes (default: CPU cores × 2 + 1)
# Formula: (2 × CPU cores) + 1
GUNICORN_WORKERS=4

# Number of threads per worker (default: 4)
# Each worker can handle this many concurrent requests
# Recommended: 2-4 threads per worker for I/O-bound applications
GUNICORN_THREADS=4

# Worker class (default: gthread)
# Options: gthread (recommended for WebSocket), sync, gevent
# gthread provides threading support needed for non-blocking WebSocket operations
GUNICORN_WORKER_CLASS=gthread

# Gunicorn timeout in seconds (default: 300)
# Workers silent for more than this many seconds are killed and restarted.
# For AI chat/agent (tool calls + streaming), use at least 180–300 to avoid mid-run timeouts.
# If you see timeouts at ~50–60s, check this and any reverse proxy/load balancer timeout.
GUNICORN_TIMEOUT=300

# Gunicorn Development Threads (only used in dev mode with USE_GUNICORN_DEV=true)
# Number of threads per worker in development (default: 4)
GUNICORN_DEV_THREADS=4

# Security Headers
# ----------------------------------------------------------------------------
# Enable security headers (HSTS, CSP, X-Frame-Options, etc.)
# Set to 'true' to enable security headers, 'false' to disable
SECURITY_HEADERS_ENABLED=true

# Content Security Policy (CSP) Reporting
# Optional: URL for CSP violation reports
# Example: https://your-domain.com/csp-report
CSP_REPORT_URI=

# Static File Versioning (OPTIONAL)
# ----------------------------------------------------------------------------
# Leave this unset for development.
# The app will auto-generate a per-boot version so restarting the app refreshes
# cached JS/CSS and Service Worker caches.
#
# In production, you may set this to a stable release/build id if desired.
# The Backoffice reads one of these, in order: ASSET_VERSION, GIT_SHA, RELEASE_VERSION
# ASSET_VERSION=
# GIT_SHA=
# RELEASE_VERSION=

# Notification Configuration
# ----------------------------------------------------------------------------
# Deduplication window in minutes (prevents duplicate notifications within this time)
NOTIFICATION_DEDUP_WINDOW_MINUTES=5
# Admin UI can use a tighter deduplication window (minutes)
# NOTIFICATION_DEDUP_WINDOW_MINUTES_ADMIN=1

# Grouping window in minutes (groups notifications of the same type within this time)
NOTIFICATION_GROUPING_WINDOW_MINUTES=60

# Notification retention/cleanup (days)
# NOTIFICATION_EXPIRATION_DAYS=90
# NOTIFICATION_CLEANUP_RETENTION_DAYS=90

# Notification rate limiting
# MAX_NOTIFICATIONS_PER_USER_PER_HOUR=100
# MAX_NOTIFICATIONS_GLOBAL_PER_HOUR=10000

# Notification feature flags
# FEATURES_NOTIFICATIONS_WEBSOCKET_ENABLED=true
# FEATURES_NOTIFICATIONS_PUSH_ENABLED=true
# FEATURES_NOTIFICATIONS_EMAIL_DIGESTS_ENABLED=true
# FEATURES_NOTIFICATIONS_ANALYTICS_ENABLED=true
# FEATURES_NOTIFICATIONS_WEBHOOKS_ENABLED=false

# RBAC maintenance (optional)
# Auto-seed RBAC on startup in production/staging by default. Override with true/false.
# AUTO_SEED_RBAC_ON_STARTUP=

# Auto-approve country access requests (default: false / disabled).
# When set to true, incoming country access requests are granted immediately
# without admin review.  Use with caution.
# AUTO_APPROVE_ACCESS_REQUESTS=false

# Development-only: allow overriding SESSION_COOKIE_SECURE
# SESSION_COOKIE_SECURE=

# ============================================================================
# LEGACY SETTINGS FILE + ORGANIZATION BRANDING (OPTIONAL)
# ============================================================================
# Settings are normally stored in the database (system_settings). These env vars
# are legacy fallbacks and should generally be left unset.
## (Optional) Legacy settings path override
# APP_SETTINGS_PATH=

# Organization branding fallback (normally stored in DB under organization_branding)
# Base URL for external Indicator Bank detail pages (admin grid ID links), no trailing slash.
# INDICATOR_BANK_PUBLIC_BASE=https://example.org
# ORGANIZATION_NAME=
# ORGANIZATION_SHORT_NAME=
# ORGANIZATION_DOMAIN=
# ORGANIZATION_EMAIL_DOMAIN=
# ORGANIZATION_LOGO_PATH=
# ORGANIZATION_COPYRIGHT_YEAR=


# ============================================================================
# DEVELOPMENT & TESTING CONFIGURATION
# ============================================================================

# Test User Passwords (Development Only)
# ----------------------------------------------------------------------------
# SECURITY: These are only used in non-production environments
# If not set, secure random passwords are generated automatically
# Test credentials are BLOCKED in production for security
#
# Test user passwords (optional - auto-generated if not set).
# NOTE: quick-login buttons on the login page are only enabled when both
# TEST_ADMIN_PASSWORD and TEST_FOCAL_PASSWORD are explicitly set.
TEST_SYS_MANAGER_PASSWORD=
TEST_ADMIN_PASSWORD=
TEST_FOCAL_PASSWORD=

# DANGEROUS development bypass (never enable in production/staging)
# ----------------------------------------------------------------------------
# When true and DEBUG is enabled, some admin routes may auto-login a system manager.
# The app will refuse to start if DEBUG_SKIP_LOGIN=true while DEBUG=false.
DEBUG_SKIP_LOGIN=false

# Debug Endpoints
# ----------------------------------------------------------------------------
# Database diagnostics endpoint /dbinfo.
# Enabled by default (true) for all environments. The endpoint is still
# protected by system-manager auth and localhost-only access in production.
# Set to false to hide the endpoint entirely.
# ENABLE_DBINFO=true

# Maintenance / migrations endpoint
# ----------------------------------------------------------------------------
# Exposes a restricted migrate endpoint used for controlled deployments.
# Enabled by default (true) for all environments. The endpoint is still
# protected by system-manager auth or a valid MIGRATE_TOKEN.
# Set to false to hide the endpoint entirely.
# ENABLE_MIGRATE=true
# Shared secret required for token-based access (must be 32+ chars)
MIGRATE_TOKEN=

# ============================================================================
# UPDATE CHECKS
# ============================================================================
# Version shown in admin UI and compared to GitHub releases (optional leading v stripped).
# Deploy workflow sets APP_VERSION from GitHub releases/latest (LATEST_RELEASE_TAG build-arg).
# RELEASE_VERSION is only the image tag stream (e.g. v1.7), not used for APP_VERSION.
# APP_VERSION=1.0.2
# GitHub repository (owner/repo) to check for new releases.
# Example: GITHUB_REPO=your-org/your-repo
# GITHUB_REPO=
# Personal access token for private repos (fine-grained token with Contents:read).
# GITHUB_TOKEN=
